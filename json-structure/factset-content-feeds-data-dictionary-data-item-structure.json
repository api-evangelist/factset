{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "DataItem",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "entitled": {
      "type": "boolean"
    },
    "dataFeed": {
      "type": "boolean"
    },
    "api": {
      "type": "boolean"
    },
    "referenceDataFeed": {
      "type": "boolean"
    }
  }
}