              },
              {
                "name": "includeMedia",
                "value": "",
                "type": "query"
              },
              {
                "name": "_attributes",
                "value": "",
                "type": "query",
                "description": "Limit the attributes returned in the response to the specified set."
              },
              {
                "name": "_language",
                "value": "",
