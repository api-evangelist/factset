          "id": "869340a6-6ba7-4f78-9354-6a230e242e09",
          "name": "Returns the Filings Documents and Related Metadata Within Factset Coverage.",
          "request": {
            "name": "Returns the Filings Documents and Related Metadata Within Factset Coverage.",
            "description": {
              "content": "Returns the filings documents within FactSet coverage along with other response fields",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "search"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "ids",
                  "value": "<string>,<string>",
                  "description": "Requested symbols or securities.  This is a comma-separated list with a maximum limit of 1000.  Each symbol can be a FactSet exchange symbol, CUSIP, or SEDOL."
                },
                {
                  "disabled": false,
                  "key": "startDate",
                  "value": "0",
                  "description": "Start Date. Format is YYYYMMDD or relative +/- days (0,-1,etc)."
                },
                {
                  "disabled": false,
                  "key": "endDate",
                  "value": "0",
                  "description": "End Date. Format is YYYYMMDD or relative +/- days (0,-1,etc)."
                },
                {
                  "disabled": false,
                  "key": "paginationLimit",
                  "value": "25",
                  "description": "Number of results to return per page."
                },
                {
                  "disabled": false,
                  "key": "paginationOffset",
                  "value": "<integer>",
                  "description": "Page number of the results to return."
                },
                {
                  "disabled": false,
                  "key": "timezone",
                  "value": "America/New_York",
                  "description": "Time zone to return story dates and times. Time zones are in POSIX format and automatically adjusted for daylight savings."
                },
                {
                  "disabled": false,
                  "key": "sort",
                  "value": "desc",
                  "description": "Sorting the results in chronological (oldest to newest) or reverse chronological (newest to oldest) order. \n\n *  desc - sorting results in reverse chronological (descending) order. This is the default value if\n    the sort parameter isnt used in the query\n    \n *   asc - sorting results in chronological (ascending) order. If a start date is not specified, the\n   API has a 10-year searching limitation. "
                },
                {
                  "disabled": false,
                  "key": "sources",
                  "value": "<string>,<string>",
                  "description": "(Required) Code for document source to include.  This is a comma-separated list. Use the ```/helper``` endpoint to get the list of available sources."
                },
                {
                  "disabled": false,
                  "key": "categories",
                  "value": "<string>,<string>",
                  "description": "Code for categories to include.  This is a comma-separated list. Use the ```/helper``` endpoint to get the list of available categories.\n\nDefault = All categories."
                },
                {
                  "disabled": false,
                  "key": "primaryId",
                  "value": "N",
                  "description": "Type of identifier search\n* Y - Returns headlines of stories that have the search ID(s) as the Primary ID.\n* N - Returns headlines of stories that mention/refer to the ID(s)."
                },
                {
                  "disabled": false,
                  "key": "searchText",
                  "value": "<string>",
                  "description": "Restricts the search to include only document stories which include the text searched."
                },
                {
                  "disabled": false,
                  "key": "formType",
                  "value": "<string>",
                  "description": "Restricts the search to include any form types of EDGAR."
                },
                {
                  "disabled": false,
                  "key": "accession",
                  "value": "<string>",
                  "description": "A unique identifier given to each EDGAR filings document. e.g. accession=0001013237-21-000069&sources=EDG"
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
