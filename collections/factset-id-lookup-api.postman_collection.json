          "id": "13573488-9e1b-47ba-93c3-5122a2539a6c",
          "name": "Search Funtionality to Return Tickers, Company Names and Unique Identifiers for Factset Data",
          "request": {
            "name": "Search Funtionality to Return Tickers, Company Names and Unique Identifiers for Factset Data",
            "description": {
              "content": "Service will accept request in JSON formatted request body. The request is sent by passing a query which is an array conitaining search query objects with parameters. The parameters contain search term and filters defined by the end user. This would display a specific set of identifiers based on the request.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v1",
                "idsearch"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": {\n    \"pattern\": \"<string>\",\n    \"entities\": [\n      \"<string>\",\n      \"<string>\"\n    ],\n    \"filters\": {\n      \"include\": [\n        {\n          \"field\": \"<string>\",\n          \"entity\": \"<string>\",\n          \"values\": [\n            \"<object>\",\n            \"<object>\"\n          ]\n        },\n        {\n          \"field\": \"<string>\",\n          \"entity\": \"<string>\",\n          \"values\": [\n            \"<object>\",\n            \"<object>\"\n          ]\n        }\n      ],\n      \"exclude\": [\n        {\n          \"field\": \"<string>\",\n          \"entity\": \"<string>\",\n          \"values\": [\n            \"<object>\",\n            \"<object>\"\n          ]\n        },\n        {\n          \"field\": \"<string>\",\n          \"entity\": \"<string>\",\n          \"values\": [\n            \"<object>\",\n            \"<object>\"\n          ]\n        }\n      ]\n    }\n  },\n  \"settings\": {\n    \"result_limit\": \"<integer>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "a49530ff-337a-406d-9d91-43a269131a5e",
              "name": "A list of securities",
              "originalRequest": {
                "url": {
                  "path": [
                    "v1",
                    "idsearch"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
